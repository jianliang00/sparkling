{
  "$schema": "https://typedoc.org/schema.json",
  "entryPoints": ["src/app-config.ts"],
  "tsconfig": "tsconfig.typedoc.json",
  "plugin": ["typedoc-plugin-markdown"],
  "out": "../../docs/en/apis/app-config",
  "readme": "none",
  "flattenOutputFiles": true,
  "fileExtension": ".mdx",
  "useCodeBlocks": true,
  "interfacePropertiesFormat": "list",
  "hidePageHeader": true,
  "hideBreadcrumbs": true,
  "disableSources": true,
  "blockTags": [
    "@defaultValue",
    "@deprecated",
    "@example",
    "@param",
    "@platform",
    "@remarks",
    "@returns",
    "@see",
    "@throws",
    "@typeParam"
  ]
}
